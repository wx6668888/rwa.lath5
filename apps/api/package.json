{
  "name": "@rwa-lat/api",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "nest build",
    "start": "node dist/main.js",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main.js",
    "lint": "tsc --noEmit",
    "test": "jest --runInBand",
    "test:unit:low-memory": "node scripts/test-unit-low-memory.mjs",
    "test:database:low-memory": "node scripts/test-database-low-memory.mjs",
    "test:integration": "jest --runInBand test/identity-schema.integration.spec.ts test/wallet-ledger-schema.integration.spec.ts test/ledger-reconciliation-schema.integration.spec.ts test/polymarket-schema.integration.spec.ts",
    "build:low-memory": "node --max-old-space-size=1024 node_modules/@nestjs/cli/bin/nest.js build",
    "verify:migration-contract": "node scripts/verify-migration-contract.mjs",
    "verify:migration-rehearsal": "node scripts/verify-migration-rehearsal.mjs",
    "db:migration:run": "typeorm-ts-node-commonjs migration:run -d src/database/data-source.ts",
    "db:migration:run:prod": "typeorm migration:run -d dist/database/data-source.js",
    "db:migration:revert": "typeorm-ts-node-commonjs migration:revert -d src/database/data-source.ts",
    "db:migration:show": "typeorm-ts-node-commonjs migration:show -d src/database/data-source.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.500.0",
    "@aws-sdk/s3-request-presigner": "^3.500.0",
    "@nestjs/common": "^11.0.1",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.0.1",
    "@nestjs/platform-express": "^11.0.1",
    "@nestjs/swagger": "^11.0.0",
    "@nestjs/terminus": "^11.0.0",
    "@nestjs/typeorm": "^11.0.3",
    "@noble/curves": "1.6.0",
    "@noble/hashes": "2.2.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.78.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.4.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.40.0",
    "@rwa-lat/contracts": "file:../../packages/contracts",
    "@simplewebauthn/server": "^13.3.2",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "helmet": "^8.0.0",
    "nest-winston": "^1.9.0",
    "nodemailer": "^9.0.3",
    "pg": "^8.22.0",
    "prom-client": "^15.1.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "typeorm": "^1.0.0",
    "winston": "^3.13.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@types/express": "^5.0.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.3"
  }
}
